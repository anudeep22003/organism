# Stack config example — for new projects starting from this template.
#
# HOW TO USE:
#   1. Edit Pulumi.yaml first:
#        - Change `name:` to your project name  (e.g. myapp-infra)
#        - Change the `storyengine-infra:app:` key to `myapp-infra:app: myapp`
#   2. Run `make init-project` — generates Pulumi.main.yaml with the correct
#      key prefix and an auto-generated media_bucket_suffix.
#      (or copy this file manually to Pulumi.<stack>.yaml and edit it)
#   3. Fill in every <...> placeholder.
#   4. pulumi stack init main
#   5. make up
#
# KEY PREFIX NOTE:
#   Every `storyengine-infra:` key below must match the `name:` field in
#   Pulumi.yaml. If you renamed the project to `myapp-infra`, replace
#   every occurrence of `storyengine-infra:` with `myapp-infra:`.
#   `make init-project` does this automatically — prefer that over copying
#   this file manually.
#
# NOTE: no `encryptionsalt:` line here — Pulumi generates that automatically
# when you run `pulumi stack init`.

config:
  gcp:project: <your-gcp-project-id>            # e.g. my-gcp-project-123
  gcp:region: <your-region>                      # e.g. europe-west2

  storyengine-infra:app: <your-app-name>         # lowercase, no spaces — drives all GCP resource names
                                                 # e.g. myapp → resources named myapp-main-backend, myapp-main-postgres, etc.

  storyengine-infra:domain: <app.yourdomain.com> # frontend domain — GCS bucket + SSL cert + LB host rule
  storyengine-infra:api_domain: <api.yourdomain.com> # API domain — Cloud Run via same LB

  storyengine-infra:github_repo: <owner/repo>    # SECURITY: only this GitHub repo can authenticate
                                                 # via Workload Identity Federation. Set correctly
                                                 # before first deploy. e.g. acme/myapp

  storyengine-infra:media_bucket_suffix: <run: openssl rand -hex 2>
                                                 # Short random string for GCS bucket name uniqueness.
                                                 # Generate: openssl rand -hex 2  (gives 4 hex chars)
                                                 # IMMUTABLE after first deploy — changing it
                                                 # recreates the bucket and loses all stored media.

  storyengine-infra:image_tag: latest            # Starting value — updated automatically by
                                                 # make deploy-backend on every deploy. Leave as-is.
